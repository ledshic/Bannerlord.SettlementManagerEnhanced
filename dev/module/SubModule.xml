<?xml version="1.0" encoding="utf-8"?>
<Module>
  <Name value="Bannerlord Settlement Manager Enhanced"/>
  <Id value="Bannerlord.SettlementManagerEnhanced"/>
  <Version value="__VERSION__"/>
  <DefaultModule value="false"/>
  <SingleplayerModule value="true"/>
  <MultiplayerModule value="false"/>
  <Official value="false"/>

  <!-- Required dependencies. Order matters for loading. -->
  <DependedModules>
    <!-- Core game modules -->
    <DependedModule Id="Native"/>
    <DependedModule Id="SandBoxCore"/>
    <DependedModule Id="Sandbox"/>
    <!-- StoryMode is optional for people playing without the main story -->
    <DependedModule Id="StoryMode" Optional="true"/>

    <!-- BUTR / MCM stack - Harmony MUST be first among these.
         Use the latest compatible versions of these libraries for your Bannerlord version
         (recommended via Steam Workshop or Nexus). -->
    <DependedModule Id="Bannerlord.Harmony"/>
    <DependedModule Id="Bannerlord.ButterLib"/>
    <DependedModule Id="Bannerlord.UIExtenderEx"/>
    <DependedModule Id="Bannerlord.MBOptionScreen"/>
  </DependedModules>

  <SubModules>
    <SubModule>
      <Name value="Bannerlord.SettlementManagerEnhanced"/>
      <!-- The DLL that contains your SubModule class -->
      <DLLName value="Bannerlord.SettlementManagerEnhanced.dll"/>
      <!-- Fully qualified class name: Namespace.Class -->
      <SubModuleClassType value="Bannerlord.SettlementManagerEnhanced.SubModule"/>
      <Tags>
        <!-- Dedicated servers: none (this is a singleplayer QoL mod) -->
        <Tag key="DedicatedServerType" value="none"/>
        <!-- Render mode element: false for most campaign mods -->
        <Tag key="IsNoRenderModeElement" value="false"/>
      </Tags>
    </SubModule>
  </SubModules>

  <!--
    If your mod ships custom XML data (new troops, items, etc.), declare them here.
    Example:
    <Xmls>
      <XmlNode>
        <XmlName id="NPCCharacters" path="troop_changes"/>
      </XmlNode>
    </Xmls>
  -->
</Module>
